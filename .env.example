# ============================================
# Stellux - Docker Environment Config
# ============================================
# Copy this file to .env and update the values
#   cp .env.example .env

# -----------------
# 必须修改的配置
# -----------------

# 数据库密码（生产环境必须修改）
POSTGRES_PASSWORD=your-secure-password-here

# JWT 密钥（至少32个字符，用于用户认证）
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters

# RustFS 存储密码
RUSTFS_SECRET_KEY=your-secure-rustfs-secret-key

# -----------------
# 前端 API 地址（重要！）
# -----------------
# 浏览器访问后端的地址，必须改为你的服务器 IP 或域名
# 格式: http://<你的服务器IP>:<后端端口>/api/v1
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:8088/api/v1

# -----------------
# 可选配置（一般不需要修改）
# -----------------

# 数据库
POSTGRES_DB=stellux
POSTGRES_USER=stellux
POSTGRES_PORT=5432

# 后端端口
BACKEND_PORT=8088
SERVER_PORT=8088

# 前端端口
FRONTEND_PORT=3000

# RustFS
RUSTFS_ACCESS_KEY=stelluxadmin

# JWT
JWT_ACCESS_TOKEN_EXPIRE_HOURS=720
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# 日志级别 (debug, info, warn, error)
RUST_LOG=warn

# 数据库连接池
DATABASE_MAX_CONNECTIONS=25
DATABASE_MIN_CONNECTIONS=3
DATABASE_ACQUIRE_TIMEOUT_SECS=10
DATABASE_IDLE_TIMEOUT_SECS=600
DATABASE_MAX_LIFETIME_SECS=1800

# 服务器
SERVER_MAX_BODY_SIZE_MB=50

# -----------------
# Docker 预构建镜像（可选）
# -----------------
# 使用 GHCR 预构建的多架构镜像，无需本地构建
# BACKEND_IMAGE=ghcr.io/sexyfeifan/stellux-backend:latest
# FRONTEND_IMAGE=ghcr.io/sexyfeifan/stellux-frontend:latest
